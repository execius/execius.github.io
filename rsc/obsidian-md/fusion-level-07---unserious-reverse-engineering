```c

int write_lib(char *path,char *src,uint lengtht)

{
  int fd;
  uint write_ret;
  uint i;
  
  for (i = 0; i < lengtht; i = i + 1) {
    src[i] = src[i] ^ 0xa5;
  }
  fd = open(path,0x241,0x1c0);
  if (fd == -1) {
    fd = -1;
  }
  else {
    write_ret = write(fd,src,lengtht);
    if (write_ret == lengtht) {
      close(fd);
      fd = 0;
    }
    else {
      close(fd);
      fd = -1;
    }
  }
  return fd;
}
